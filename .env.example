# Server
PORT=3000

# DeepSeek (OpenAI-compatible: base URL 通常包含 /v1)
# 文档: https://api-docs.deepseek.com/
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# 小米 MiMo（OpenAI 兼容模式：将官方或代理提供的 OpenAI Base URL 填在这里）
# 若你使用其它网关，请改为对应 base，例如 https://api.example.com/v1
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEY=your_mimo_api_key
MIMO_MODEL=mimo-v2-flash

# 智谱 GLM（OpenAI 兼容 v4）
# 文档: https://open.bigmodel.cn/dev/api
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=your_zhipu_api_key
GLM_MODEL=glm-4-flash

# Vercel：在 Project → Settings → Environment Variables 配置同名变量（勿上传 .env）。
# Vercel：使用 `src/index.js` 导出 Express（与官方示例一致）；勿依赖根目录 server.js。
# 流式若超时：Vercel → Settings → Functions 里调高该项目的 Max Duration（依套餐）。
